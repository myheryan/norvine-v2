generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
  REFUNDED 
  FAILED
}

enum ShipmentStatus {
  PENDING        
  PAID
  PROCESSING     
  READY_TO_SHIP  
  SHIPPED        
  DELIVERED      
  REFUNDED
  CANCELLED
  FAILED         
}

enum ActionStatus {
  PENDING
  APPROVED
  REFUNDED
  REJECTED
}

enum PrintStatus {
  NOT_PRINTED
  PRINTED
}

// --- USER & AUTH ---

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  name             String?
  password         String?
  role             String    @default("USER")
  phoneNumber      String?
  image            String?
  birth            DateTime?
  emailVerified    DateTime?
  
  lastLoginAt      DateTime? @default(now())
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @default(now()) @updatedAt

  accounts              Account[]
  sessions              Session[]
  addresses             Address[]
  cartItems             CartItem[]
  transactions          Transaction[]
  orderHistories        OrderHistory[]
  refundRequests        RefundRequest[]
  cancellationRequests  CancellationRequest[] 
  requestGenerates      RequestGenerate[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String
  recipient   String
  phone       String
  fullAddress String
  province    String
  city        String
  district    String
  postalCode  String
  isMain      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- PRODUCT & INVENTORY ---

model Product {
  id                   String   @id @map("key")
  regNumber            String?
  name                 String
  thumbnailUrl         String?
  images               String[]
  thumbnailDescription String?
  description          String?
  usage                String?
  howMedWorks          String?
  howToStore           String?
  caution              String?
  sideEffect           String?
  warning              String?
  tag                  String[]
  attributes           Json?
  isAvailable          Boolean  @default(true)
  isDisplayOnly        Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  variants   ProductVariant[]
  orderItems OrderItem[]
  promos     Promo[]           @relation("ProductPromos")
  categories Category[]        @relation("ProductCategories")
  types      Type[]            @relation("ProductTypes")
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  sku         String?   @unique
  name        String
  price       Int
  weight      Float?    @default(0)
  dimensions  Json?
  stock       Int       @default(0)
  barcode     Json?
  imageUrl    String?
  isPreOrder  Boolean   @default(false)
  releaseDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  stockLogs  StockLog[]
}

model StockLog {
  id        String   @id @default(cuid())
  variantId String
  change    Int
  reason    String 
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id])
}

// --- TRANSACTION & LOGISTICS ---

model Transaction {
  id              String        @id @default(cuid())
  invoice         String        @unique
  userId          String
  status          PaymentStatus @default(PENDING) // Status Keuangan
  notes           String?
  
  subtotal        Int           @default(0)
  discount        Int           @default(0)
  shippingCost    Int           @default(0)
  insuranceCost   Int           @default(0)
  taxAmount       Int           @default(0)
  serviceFee      Int           @default(0)
  totalAmount     Int           @default(0)

  paymentMethod   String
  midtransOrderId String?       @unique
  bankName        String?
  vaNumber        String?
  paymentCode     String?
  qrUrl           String?
  paymentExpiry   DateTime?
  rawPaymentRes   Json?

  promoId         Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  promo           Promo?        @relation(fields: [promoId], references: [id])
  items           OrderItem[]
  history         OrderHistory[]
  shipment        Shipment?  
  shippingAddress OrderAddress?
  refundRequest   RefundRequest?
  cancellationRequest CancellationRequest?
  
  @@index([userId])
  @@index([status])
}

model OrderAddress {
  id              String      @id @default(cuid())
  transactionId   String      @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  recipientName   String
  recipientPhone  String
  fullAddress     String
  province        String
  city            String
  district        String
  postalCode      String
  createdAt       DateTime    @default(now())
}

model Shipment {
  id              String         @id @default(cuid())
  transactionId   String         @unique
  transaction     Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  status          ShipmentStatus @default(PENDING) // Status Logistik
  isInsurance     Boolean        @default(false)
  insuranceAmount Int            @default(0)
  awbNumber       String?        @unique 
  courierCode     String
  courierService  String
  
  destination     String? 
  originCode      String?   
  weight          Float          @default(0)
  apiPayload      Json?
  
  printStatus     PrintStatus    @default(NOT_PRINTED)
  printCount      Int            @default(0) 
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model OrderItem {
  id              String   @id @default(cuid())
  transactionId   String
  productId       String
  variantId       String?
  quantity        Int      @default(1)
  priceAtBuy      Int
  weightAtBuy     Float?
  createdAt       DateTime @default(now())

  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model OrderHistory {
  id            String         @id @default(cuid())
  transactionId String
  status        String
  notes         String?
  updatedById   String?
  createdAt     DateTime       @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  updatedBy   User?       @relation(fields: [updatedById], references: [id])
}


model Promo {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  type        String
  value       Int
  minOrder    Int       @default(0)
  maxDiscount Int?
  limit       Int       @default(0)
  used        Int       @default(0)
  status      String    @default("ACTIVE")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  applicableProducts Product[]     @relation("ProductPromos")
  transactions        Transaction[]

  @@index([status, startDate, endDate])
  @@index([code])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
}

model Category {
  id       String    @id
  name     String
  products Product[] @relation("ProductCategories")
}

model Type {
  id       String    @id
  name     String
  products Product[] @relation("ProductTypes")
}

model Warehouse {
  id              String   @id @default(cuid())
  name            String   
  contactName     String   
  phoneNumber     String   
  fullAddress         String   
  province        String
  city            String
  district        String
  postalCode      String
  lionOriginCode  String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RequestGenerate {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  url       String
  quantity  Int
  createdAt DateTime @default(now())

  header        Header?
  serialNumbers SerialNumber[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Header {
  id                Int             @id @default(autoincrement())
  header            String          @unique
  requestGenerateId Int             @unique
  requestGenerate   RequestGenerate @relation(fields: [requestGenerateId], references: [id], onDelete: Cascade)
}

model SerialNumber {
  id                Int              @id @default(autoincrement())
  serial            String           @unique
  totalCheck        Int              @default(0)
  requestGenerateId Int?
  requestGenerate   RequestGenerate? @relation(fields: [requestGenerateId], references: [id], onDelete: Cascade)
  checks            Check[]
}

model Check {
  id             Int      @id @default(autoincrement())
  serialNumberId Int
  city           String
  subdistrict    String
  lat            Decimal
  long           Decimal
  createdAt      DateTime @default(now())

  serialNumber SerialNumber @relation(fields: [serialNumberId], references: [id], onDelete: Cascade)
}

model RefundRequest {
  id            String       @id @default(cuid())
  transactionId String       @unique
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  amount        Int
  reason        String
  status        ActionStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model CancellationRequest {
  id            String       @id @default(cuid())
  transactionId String       @unique
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  reason        String
  amount        Int
  status        ActionStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String   @unique
  token      String
  expires    DateTime
  attempts   Int      @default(0)
  lastSent   DateTime @default(now())
}