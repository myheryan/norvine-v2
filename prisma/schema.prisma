generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- USER & AUTH ---
model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  name             String?
  password         String?
  role             String    @default("USER")
  phoneNumber      String?
  image            String?
  birth            DateTime?
  emailVerified    DateTime?
  
  // Auth & Session
  lastLoginAt      DateTime? @default(now())
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @default(now()) @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  addresses        Address[]
  cartItems        CartItem[]
  transactions     Transaction[]
  orderHistories   OrderHistory[]
  refundRequests    RefundRequest[]
  requestGenerates RequestGenerate[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String
  recipient   String
  phone       String
  fullAddress String
  province    String
  city        String
  district    String
  postalCode  String
  isMain      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String   @unique
  token      String
  expires    DateTime
  attempts   Int      @default(0)
  lastSent   DateTime @default(now())
}

// --- PRODUCT & INVENTORY ---
model Product {
  id                   String   @id @map("key")
  regNumber            String?
  name                 String
  thumbnailUrl         String?
  images               String[]
  thumbnailDescription String?
  description          String?
  usage                String?
  howMedWorks          String?
  howToStore           String?
  caution              String?
  sideEffect           String?
  warning              String?
  tag                  String[]
  attributes           Json?
  isAvailable          Boolean  @default(true)
  isDisplayOnly        Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  variants   ProductVariant[]
  orderItems OrderItem[]
  promos     Promo[]
  categories Category[]       @relation("ProductCategories")
  types      Type[]           @relation("ProductTypes")
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  sku         String?   @unique
  name        String
  price       Int
  weight      Float?    @default(0)
  dimensions  Json?
  stock       Int       @default(0)
  barcode     Json?
  imageUrl    String?
  isPreOrder  Boolean   @default(false)
  releaseDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  stockLogs  StockLog[]
}

model StockLog {
  id        String   @id @default(cuid())
  variantId String
  change    Int
  reason    String // "SALE", "RESTOCK", "RETURN"
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id])
}


model OrderAddress {
  id             String      @id @default(cuid())
  transactionId  String      @unique
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Data Snapshot
  recipientName  String
  recipientPhone String
  fullAddress    String
  province       String
  city           String
  district       String
  postalCode     String
  
  createdAt      DateTime    @default(now())
}



// --- TRANSACTION & LOGISTICS ---
model Transaction {
  id              String      @id @default(cuid())
  invoice         String      @unique
  userId          String
  status          OrderStatus @default(PENDING)
  notes           String?
  
  // Amounts
  subtotal        Int         @default(0)
  discount        Int         @default(0)
  shippingCost    Int         @default(0)
  insuranceCost   Int         @default(0)
  taxAmount       Int         @default(0)
  serviceFee      Int         @default(0)
  totalAmount     Int         @default(0)

  shippingAddress OrderAddress?
  waybill         String? 

  paymentMethod   String
  midtransOrderId String?     @unique
  bankName        String?
  vaNumber        String?
  paymentCode     String?
  qrUrl           String?
  deepLink        String?
  paymentExpiry   DateTime?
  rawPaymentRes   Json?

  promoId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  promo    Promo?         @relation(fields: [promoId], references: [id])
  items    OrderItem[]
  history  OrderHistory[]
  shipment Shipment?  
  refundRequest RefundRequest?

  @@index([userId])
  @@index([status])
}


model Shipment {
  id             String      @id @default(cuid())
  transactionId  String      @unique
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Data Identitas Pengiriman
  isInsurance    Boolean  @default(false)
  insuranceAmount Int      @default(0)
  awbNumber      String?     @unique // No Resi / STT
  courierCode    String     
  courierService String      
  
  // Data Teknis Rute (Dipindahkan dari Transaction)
  destination     String? 
  originCode      String?   
  destinationCode String?   
  ursaCode        String?    

  // Operasional
  status         String      @default("PENDING")
  weight         Float       @default(0)
  apiPayload     Json?       

  printStatus     PrintStatus    @default(NOT_PRINTED)
  printCount      Int            @default(0) 
  firstPrintedAt  DateTime?     
  lastPrintedAt   DateTime?      
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id              String  @id @default(cuid())
  transactionId   String
  productId       String
  variantId       String?
  quantity        Int     @default(1)
  priceAtBuy      Int
  weightAtBuy     Float?
  dimensionsAtBuy Json?
  createdAt       DateTime @default(now())

  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model OrderHistory {
  id            String      @id @default(cuid())
  transactionId String
  status        OrderStatus
  notes         String?
  updatedById   String?
  createdAt     DateTime    @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  updatedBy   User?       @relation(fields: [updatedById], references: [id])
}

model Promo {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  type        String
  value       Int
  minOrder    Int       @default(0)
  maxDiscount Int?
  limit       Int       @default(0)
  used        Int       @default(0)
  status      String    @default("ACTIVE")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  applicableProducts Product[]
  transactions       Transaction[]

  @@index([status, startDate, endDate])
  @@index([code])
}

model Category {
  id       String    @id
  name     String
  products Product[] @relation("ProductCategories")
}

model Type {
  id       String    @id
  name     String
  products Product[] @relation("ProductTypes")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
}

model ShippingProvider {
  id        Int      @id @default(autoincrement())
  code      String   @unique // "LION_PARCEL"
  name      String
  isActive  Boolean  @default(true)
  apiKey    String?
  config    Json?    // e.g., origin_postal_code
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id              String   @id @default(cuid())
  name            String   
  contactName     String   
  phoneNumber     String   
  address         String   
  
  province        String
  city            String
  district        String
  postalCode      String
  
  lionOriginCode  String?
  
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}



model Header {
  id                Int             @id @default(autoincrement())
  header            String          @unique
  requestGenerateId Int             @unique
  requestGenerate   RequestGenerate @relation(fields: [requestGenerateId], references: [id], onDelete: Cascade)
}

model SerialNumber {
  id                Int              @id @default(autoincrement())
  serial            String           @unique
  totalCheck        Int              @default(0)
  requestGenerateId Int?
  requestGenerate   RequestGenerate? @relation(fields: [requestGenerateId], references: [id], onDelete: Cascade)
  checks            Check[]
}

model Check {
  id             Int          @id @default(autoincrement())
  serialNumberId Int
  city           String
  county         String
  district       String
  subdistrict    String
  lat            Decimal
  long           Decimal
  createdAt      DateTime     @default(now())

  serialNumber SerialNumber @relation(fields: [serialNumberId], references: [id], onDelete: Cascade)
}

model RequestGenerate {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  url       String
  quantity  Int
  createdAt DateTime @default(now())

  header        Header?
  serialNumbers SerialNumber[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefundRequest {
  id            String       @id @default(cuid())
  transactionId String       @unique
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  amount        Int
  reason        String
  status        RefundStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PrintStatus {
  NOT_PRINTED
  PRINTED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING     
  READY_TO_SHIP  
  SHIPPED
  COMPLETED
  CANCELLED
  EXPIRED
  REFUNDED
  FAILED
}

